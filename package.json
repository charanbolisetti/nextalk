{
  "name": "nextalk",
  "version": "1.0.0",
  "description": "Real-time chat application built with Next.js, Socket.io, MongoDB, and Tailwind CSS",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "server": "node server/index.js",
    "start:prod": "NODE_ENV=production node server/index.js",
    "dev:all": "concurrently \"next dev\" \"node server/index.js\"",
    "lint": "npx tsc --noEmit"
  },
  "dependencies": {
    "next": "14.2.35",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "mongoose": "^8.4.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "axios": "^1.7.2",
    "date-fns": "^3.6.0",
    "react-hot-toast": "^2.4.1",
    "zustand": "^4.5.2",
    "clsx": "^2.1.1",
    "concurrently": "^8.2.2",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "helmet": "^7.0.0",
    "express-rate-limit": "^6.9.0",
    "pino": "^8.20.0",
    "redis": "^6.1.0",
    "@socket.io/redis-adapter": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "pino-pretty": "^9.0.0"
  }
}
